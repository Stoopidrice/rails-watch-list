<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @list.name %></h1>
    <%= link_to "Add a bookmark", new_list_bookmark_path(@list), class: "btn btn-danger" %>
    <%= link_to "Home", lists_path %>
  </div>
  <% @list.bookmarks.each do |bookmark| %>
    <div class="card" style="width: 18rem;">
      <%= image_tag bookmark.movie.poster_url, class: "card-img-top" %>
      <div class="card-body">
        <h5 class="card-title">
          <%= bookmark.movie.title %>
        </h5>
        <p class="card-text">
          <%= bookmark.comment %>
        </p>
      </div>
      <%= link_to "Remove", bookmark_path(bookmark), class: "btn btn-outline-danger",
      data: {
        turbo_method: :delete,
        turbo_confirm: "Are you sure?"
      } %>
    </div>
  <% end %>
